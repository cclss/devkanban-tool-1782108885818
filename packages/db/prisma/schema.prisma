// Prisma schema for the e-signature SaaS MVP.
// Initial data model — covers users, documents, sign requests, sign fields,
// and audit logs. Business logic / queries are intentionally out of scope for
// the scaffolding grain; this only establishes the persistence layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user (the sender who creates and dispatches contracts).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?  @map("password_hash")
  // Google account subject (`sub`) for social sign-in. Null for password-only
  // accounts; set when a user signs in/links via Google.
  googleId     String?  @unique @map("google_id")
  // Sender branding (logo + brand color) — available on all plans per spec.
  brandLogoUrl String?  @map("brand_logo_url")
  brandColor   String?  @map("brand_color")
  plan         Plan     @default(FREE)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  documents Document[]
  auditLogs AuditLog[]

  @@map("users")
}

/// An uploaded PDF that a contract is built on top of.
model Document {
  id                    String                 @id @default(cuid())
  ownerId               String                 @map("owner_id")
  title                 String
  // Object storage key (e.g. S3). Stub-friendly: no cloud wiring at this grain.
  storageKey            String                 @map("storage_key")
  pageCount             Int                    @default(0) @map("page_count")
  status                DocumentStatus         @default(DRAFT)
  // Timestamp the contract was dispatched (status → IN_PROGRESS). Used to
  // count monthly sends for the Free-plan quota guard.
  sentAt                DateTime?              @map("sent_at")
  // Completion post-processing outputs (grain-5). Populated once the last
  // signer finishes and the worker has generated/stored the artifacts:
  //   • signedStorageKey      — object key of the flattened, signed final PDF
  //   • certificateStorageKey — object key of the audit-trail certificate PDF
  //   • completedAt           — when the contract completed (also the
  //     idempotency marker: a non-null value means post-processing is done).
  signedStorageKey      String?                @map("signed_storage_key")
  certificateStorageKey String?                @map("certificate_storage_key")
  completedAt           DateTime?              @map("completed_at")
  // AI clause-card extraction pipeline state (M1). Pre-generated and cached at
  // send time. READY = cards present; EMPTY = extraction succeeded but produced
  // zero cards (non-text / nothing to extract) — distinct from READY so the
  // signer UI can decide when to fall back to the full-PDF view. FAILED covers
  // extraction errors/timeouts. `clauseExtractedAt` marks when the pipeline
  // last resolved this document (success or terminal failure).
  clauseStatus          ClauseExtractionStatus @default(PENDING) @map("clause_status")
  clauseExtractedAt     DateTime?              @map("clause_extracted_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  signRequests    SignRequest[]
  signFields      SignField[]
  auditLogs       AuditLog[]
  contractClauses ContractClause[]

  @@index([ownerId])
  @@map("documents")
}

/// An AI-extracted key clause rendered as a card in the signer experience.
/// Pre-generated and cached at send time; served to signers from cache (never
/// generated on link-open). The summary is an advisory reminder — legal effect
/// remains with the source document, always reachable via the full-PDF view.
model ContractClause {
  id            String   @id @default(cuid())
  documentId    String   @map("document_id")
  // Display order of the card within the document's clause stack.
  order         Int
  title         String
  summary       String
  // Where the clause is grounded in the source PDF (page number).
  sourcePage    Int      @map("source_page")
  // Verbatim source excerpt backing the summary. Null when no snippet was
  // captured.
  sourceSnippet String?  @map("source_snippet")
  // Flags a clause that warrants the signer's attention.
  caution       Boolean  @default(false)
  cautionReason String?  @map("caution_reason")
  createdAt     DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("contract_clauses")
}

/// A request asking a single recipient to sign a document.
model SignRequest {
  id             String            @id @default(cuid())
  documentId     String            @map("document_id")
  recipientEmail String            @map("recipient_email")
  recipientName  String?           @map("recipient_name")
  // Signing order for sequential workflows.
  order          Int               @default(0)
  status         SignRequestStatus @default(PENDING)
  // Access token embedded in the signing link.
  accessToken    String            @unique @map("access_token")
  // 6-digit verification code delivered out of band.
  verifyCode     String?           @map("verify_code")
  signedAt       DateTime?         @map("signed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signFields SignField[]
  auditLogs  AuditLog[]

  @@index([documentId])
  @@map("sign_requests")
}

/// A placed field on a document page (signature, date, or free text).
model SignField {
  id             String        @id @default(cuid())
  documentId     String        @map("document_id")
  signRequestId  String?       @map("sign_request_id")
  type           SignFieldType
  // Which recipient (by 0-based order index) must fill this field. Resolved to
  // a concrete signRequestId at send time. Null = first/only signer.
  recipientIndex Int?          @default(0) @map("recipient_index")
  page           Int           @default(1)
  // Normalized geometry (0..1) relative to the page. Coordinate-system
  // conversion (PDF bottom-left vs canvas top-left) is handled in app logic.
  x              Float
  y              Float
  width          Float
  height         Float
  // Captured value once signed (signature image ref / text / date).
  value          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  document    Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signRequest SignRequest? @relation(fields: [signRequestId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([signRequestId])
  @@map("sign_fields")
}

/// Immutable trail of every meaningful action for the audit certificate.
model AuditLog {
  id            String   @id @default(cuid())
  documentId    String?  @map("document_id")
  signRequestId String?  @map("sign_request_id")
  actorId       String?  @map("actor_id")
  action        String
  // Free-form contextual metadata (IP, user agent, etc.).
  metadata      Json?
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  document    Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  signRequest SignRequest? @relation(fields: [signRequestId], references: [id], onDelete: SetNull)
  actor       User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([signRequestId])
  @@map("audit_logs")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum DocumentStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SignRequestStatus {
  PENDING
  VIEWED
  SIGNED
  DECLINED
}

enum SignFieldType {
  SIGNATURE
  DATE
  TEXT
}

enum ClauseExtractionStatus {
  PENDING
  READY
  EMPTY
  FAILED
}
