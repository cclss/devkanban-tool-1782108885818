// Prisma schema for the e-signature SaaS MVP.
// Initial data model — covers users, documents, sign requests, sign fields,
// and audit logs. Business logic / queries are intentionally out of scope for
// the scaffolding grain; this only establishes the persistence layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user (the sender who creates and dispatches contracts).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  // Registered mobile number used for the "find ID" / account-recovery flows
  // via SMS. Optional: accounts without a phone simply can't use the SMS
  // channel. Postgres treats multiple NULLs as distinct, so a UNIQUE index on a
  // nullable column is allowed and prevents two accounts sharing one number.
  phoneNumber  String?  @unique @map("phone_number")
  passwordHash String?  @map("password_hash")
  // Google account subject (`sub`) for social sign-in. Null for password-only
  // accounts; set when a user signs in/links via Google.
  googleId     String?  @unique @map("google_id")
  // Sender branding (logo + brand color) — available on all plans per spec.
  brandLogoUrl String?  @map("brand_logo_url")
  brandColor   String?  @map("brand_color")
  plan         Plan     @default(FREE)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  documents Document[]
  auditLogs AuditLog[]

  identityVerifications IdentityVerification[]
  passwordResetTokens   PasswordResetToken[]

  @@map("users")
}

/// One-time identity-verification challenge for account-recovery flows
/// (currently "find ID"). A row is created when a user requests a verification
/// code; the code itself is never stored in plaintext — only its hash. Rows are
/// created even when no matching user exists so the API can return a generic
/// response without leaking account existence.
model IdentityVerification {
  id     String              @id @default(cuid())
  // Why the challenge was issued. Modeled as an enum so future recovery flows
  // (e.g. password reset) can reuse this table.
  purpose VerificationPurpose
  // Delivery channel the code was sent over.
  channel VerificationChannel
  // Normalized recipient: lowercased email or canonicalized phone number.
  target  String              @map("target")
  // Hash of the verification code (bcrypt or sha256). Never store the plaintext.
  codeHash String             @map("code_hash")
  // Linked user when one matched the target. Null when no account matched (a
  // row is still created so responses stay generic and rate limiting applies).
  userId  String?             @map("user_id")
  // Number of failed verification attempts, for brute-force throttling.
  attempts Int                @default(0)
  // Set when the code is successfully used; a non-null value invalidates reuse.
  consumedAt DateTime?        @map("consumed_at")
  // When the challenge expires and can no longer be verified.
  expiresAt DateTime          @map("expires_at")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([channel, target])
  @@map("identity_verifications")
}

/// Single-use, short-lived password-reset token. Issued only after a user has
/// successfully verified an identity-verification code (purpose RESET_PASSWORD).
/// The plaintext token is never stored — only its SHA-256 hex digest — and is
/// handed to the client once. Confirming a reset looks the token up by hash,
/// checks it is neither expired nor already consumed, then marks it consumed so
/// it can never be replayed.
model PasswordResetToken {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  // SHA-256 hex digest of the reset token. Never store the plaintext.
  tokenHash String @map("token_hash")
  // When the token expires and can no longer be used (kept short).
  expiresAt DateTime  @map("expires_at")
  // Set when the token is used to set a new password; a non-null value
  // invalidates reuse (single-use guarantee).
  consumedAt DateTime? @map("consumed_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

/// An uploaded PDF that a contract is built on top of.
model Document {
  id        String         @id @default(cuid())
  ownerId   String         @map("owner_id")
  title     String
  // Object storage key (e.g. S3). Stub-friendly: no cloud wiring at this grain.
  storageKey String        @map("storage_key")
  pageCount Int            @default(0) @map("page_count")
  status    DocumentStatus @default(DRAFT)
  // Timestamp the contract was dispatched (status → IN_PROGRESS). Used to
  // count monthly sends for the Free-plan quota guard.
  sentAt    DateTime?      @map("sent_at")
  // Completion post-processing outputs (grain-5). Populated once the last
  // signer finishes and the worker has generated/stored the artifacts:
  //   • signedStorageKey      — object key of the flattened, signed final PDF
  //   • certificateStorageKey — object key of the audit-trail certificate PDF
  //   • completedAt           — when the contract completed (also the
  //     idempotency marker: a non-null value means post-processing is done).
  signedStorageKey      String?   @map("signed_storage_key")
  certificateStorageKey String?   @map("certificate_storage_key")
  completedAt           DateTime? @map("completed_at")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  signRequests SignRequest[]
  signFields   SignField[]
  auditLogs    AuditLog[]

  @@index([ownerId])
  @@map("documents")
}

/// A request asking a single recipient to sign a document.
model SignRequest {
  id          String            @id @default(cuid())
  documentId  String            @map("document_id")
  recipientEmail String         @map("recipient_email")
  recipientName  String?        @map("recipient_name")
  // Signing order for sequential workflows.
  order       Int               @default(0)
  status      SignRequestStatus @default(PENDING)
  // Access token embedded in the signing link.
  accessToken String            @unique @map("access_token")
  // 6-digit verification code delivered out of band.
  verifyCode  String?           @map("verify_code")
  signedAt    DateTime?         @map("signed_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signFields SignField[]
  auditLogs  AuditLog[]

  @@index([documentId])
  @@map("sign_requests")
}

/// A placed field on a document page (signature, date, or free text).
model SignField {
  id            String        @id @default(cuid())
  documentId    String        @map("document_id")
  signRequestId String?       @map("sign_request_id")
  type          SignFieldType
  // Which recipient (by 0-based order index) must fill this field. Resolved to
  // a concrete signRequestId at send time. Null = first/only signer.
  recipientIndex Int?         @default(0) @map("recipient_index")
  page          Int           @default(1)
  // Normalized geometry (0..1) relative to the page. Coordinate-system
  // conversion (PDF bottom-left vs canvas top-left) is handled in app logic.
  x             Float
  y             Float
  width         Float
  height        Float
  // Captured value once signed (signature image ref / text / date).
  value         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  document    Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signRequest SignRequest? @relation(fields: [signRequestId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([signRequestId])
  @@map("sign_fields")
}

/// Immutable trail of every meaningful action for the audit certificate.
model AuditLog {
  id            String   @id @default(cuid())
  documentId    String?  @map("document_id")
  signRequestId String?  @map("sign_request_id")
  actorId       String?  @map("actor_id")
  action        String
  // Free-form contextual metadata (IP, user agent, etc.).
  metadata      Json?
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  document    Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  signRequest SignRequest? @relation(fields: [signRequestId], references: [id], onDelete: SetNull)
  actor       User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([signRequestId])
  @@map("audit_logs")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum DocumentStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SignRequestStatus {
  PENDING
  VIEWED
  SIGNED
  DECLINED
}

enum SignFieldType {
  SIGNATURE
  DATE
  TEXT
}

/// Purpose of an identity-verification challenge. The same table backs both the
/// "find ID" flow and the password-reset code (email/SMS 6-digit) challenge.
enum VerificationPurpose {
  FIND_ID
  RESET_PASSWORD
}

/// Delivery channel for a verification code.
enum VerificationChannel {
  EMAIL
  SMS
}
