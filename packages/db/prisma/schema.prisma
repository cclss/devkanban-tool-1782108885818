// Prisma schema for the e-signature SaaS MVP.
// Initial data model — covers users, documents, sign requests, sign fields,
// and audit logs. Business logic / queries are intentionally out of scope for
// the scaffolding grain; this only establishes the persistence layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user (the sender who creates and dispatches contracts).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?  @map("password_hash")
  // Google account subject (`sub`) for social sign-in. Null for password-only
  // accounts; set when a user signs in/links via Google.
  googleId     String?  @unique @map("google_id")
  // Sender branding (logo + brand color) — available on all plans per spec.
  brandLogoUrl String?  @map("brand_logo_url")
  brandColor   String?  @map("brand_color")
  plan         Plan     @default(FREE)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  documents Document[]
  auditLogs AuditLog[]

  @@map("users")
}

/// An uploaded PDF that a contract is built on top of.
model Document {
  id        String         @id @default(cuid())
  ownerId   String         @map("owner_id")
  title     String
  // Object storage key (e.g. S3). Stub-friendly: no cloud wiring at this grain.
  storageKey String        @map("storage_key")
  pageCount Int            @default(0) @map("page_count")
  status    DocumentStatus @default(DRAFT)
  // Timestamp the contract was dispatched (status → IN_PROGRESS). Used to
  // count monthly sends for the Free-plan quota guard.
  sentAt    DateTime?      @map("sent_at")
  // Completion post-processing outputs (grain-5). Populated once the last
  // signer finishes and the worker has generated/stored the artifacts:
  //   • signedStorageKey      — object key of the flattened, signed final PDF
  //   • certificateStorageKey — object key of the audit-trail certificate PDF
  //   • completedAt           — when the contract completed (also the
  //     idempotency marker: a non-null value means post-processing is done).
  signedStorageKey      String?   @map("signed_storage_key")
  certificateStorageKey String?   @map("certificate_storage_key")
  completedAt           DateTime? @map("completed_at")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  signRequests SignRequest[]
  signFields   SignField[]
  auditLogs    AuditLog[]

  @@index([ownerId])
  @@map("documents")
}

/// A request asking a single recipient to sign a document.
///
/// Two access modes are supported (see `SignRequestAccessMode`):
///   • CODE — the original out-of-band flow: a request is addressed to a known
///     `recipientEmail` and gated by a one-time `verifyCode`.
///   • LINK — "share by link": the sender generates a self-serve link that
///     anyone holding it can open. There is no addressed recipient, so
///     `recipientEmail`/`verifyCode` are absent; access is instead governed by
///     the `link*` columns (optional password, expiry, revocation, label).
model SignRequest {
  id          String            @id @default(cuid())
  documentId  String            @map("document_id")
  // Null in LINK mode (no addressed recipient until they identify themselves).
  recipientEmail String?        @map("recipient_email")
  recipientName  String?        @map("recipient_name")
  // Signing order for sequential workflows.
  order       Int               @default(0)
  status      SignRequestStatus @default(PENDING)
  // How this request is accessed. Defaults to CODE to preserve the existing
  // out-of-band OTP behaviour for all pre-existing rows.
  accessMode  SignRequestAccessMode @default(CODE) @map("access_mode")
  // Access token embedded in the signing link.
  accessToken String            @unique @map("access_token")
  // 6-digit verification code delivered out of band. CODE mode only.
  verifyCode  String?           @map("verify_code")
  // --- LINK mode access settings (all null/ignored in CODE mode) ---
  // Hashed link password (bcrypt/argon2). Null = no password required.
  linkPasswordHash String?      @map("link_password_hash")
  // When the link stops working. Null = never expires.
  linkExpiresAt DateTime?       @map("link_expires_at")
  // When the sender manually revoked the link. Null = still active.
  linkRevokedAt DateTime?       @map("link_revoked_at")
  // Sender-facing label to tell multiple links apart. Null = unlabelled.
  linkLabel   String?           @map("link_label")
  signedAt    DateTime?         @map("signed_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signFields SignField[]
  auditLogs  AuditLog[]

  @@index([documentId])
  @@map("sign_requests")
}

/// A placed field on a document page (signature, date, or free text).
model SignField {
  id            String        @id @default(cuid())
  documentId    String        @map("document_id")
  signRequestId String?       @map("sign_request_id")
  type          SignFieldType
  // Which recipient (by 0-based order index) must fill this field. Resolved to
  // a concrete signRequestId at send time. Null = first/only signer.
  recipientIndex Int?         @default(0) @map("recipient_index")
  page          Int           @default(1)
  // Normalized geometry (0..1) relative to the page. Coordinate-system
  // conversion (PDF bottom-left vs canvas top-left) is handled in app logic.
  x             Float
  y             Float
  width         Float
  height        Float
  // Captured value once signed (signature image ref / text / date).
  value         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  document    Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signRequest SignRequest? @relation(fields: [signRequestId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([signRequestId])
  @@map("sign_fields")
}

/// Immutable trail of every meaningful action for the audit certificate.
model AuditLog {
  id            String   @id @default(cuid())
  documentId    String?  @map("document_id")
  signRequestId String?  @map("sign_request_id")
  actorId       String?  @map("actor_id")
  action        String
  // Free-form contextual metadata (IP, user agent, etc.).
  metadata      Json?
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  document    Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  signRequest SignRequest? @relation(fields: [signRequestId], references: [id], onDelete: SetNull)
  actor       User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([signRequestId])
  @@map("audit_logs")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum DocumentStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SignRequestStatus {
  PENDING
  VIEWED
  SIGNED
  DECLINED
}

/// How a SignRequest is accessed by the signer.
enum SignRequestAccessMode {
  /// Addressed recipient gated by an out-of-band one-time code (default).
  CODE
  /// Self-serve share link gated by the optional `link*` settings.
  LINK
}

enum SignFieldType {
  SIGNATURE
  DATE
  TEXT
}
