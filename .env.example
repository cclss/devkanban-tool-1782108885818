# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your local environment.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Node environment
NODE_ENV=development

# --- Database (PostgreSQL) -------------------------------------------------
# Matches the docker-compose `postgres` service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/esign?schema=public

# --- Queue / cache (Redis, BullMQ) ----------------------------------------
REDIS_URL=redis://localhost:6379

# --- API server ------------------------------------------------------------
API_PORT=3001
WEB_ORIGIN=http://localhost:3000

# --- Web app ---------------------------------------------------------------
# Base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- AWS S3 (file storage) — stubbed until later grains --------------------
# Leave blank to fall back to the local/stub storage adapter.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# --- AWS SES (email) — stubbed until later grains --------------------------
# Leave blank to log outgoing mail to the console instead of sending.
SES_FROM_EMAIL=

# --- KakaoTalk 알림톡 (notifications) --------------------------------------
# Leave blank to log notifications to the console instead of sending.
KAKAO_ALIMTALK_API_KEY=
