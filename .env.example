# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your local environment.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Node environment
NODE_ENV=development

# --- Database (PostgreSQL) -------------------------------------------------
# Matches the docker-compose `postgres` service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/esign?schema=public

# --- Queue / cache (Redis, BullMQ) ----------------------------------------
# Leave blank to log notifications to the console instead of enqueueing them.
REDIS_URL=redis://localhost:6379

# --- API server ------------------------------------------------------------
API_PORT=3001
WEB_ORIGIN=http://localhost:3000

# JWT signing secret for sender auth. Set a strong value in any shared env.
JWT_SECRET=dev-local-secret-change-me
JWT_EXPIRES_IN=7d

# Local-disk storage root used when S3 is not configured (relative to cwd).
STORAGE_DIR=.storage

# --- Web app ---------------------------------------------------------------
# Base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- AWS S3 (file storage) — stubbed until later grains --------------------
# Leave blank to fall back to the local/stub storage adapter.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# --- AWS SES (email) -------------------------------------------------------
# Verified SES "From" address used for completion emails (final PDF + audit
# certificate attachments). Leave blank to log outgoing mail to the console
# instead of sending (EmailService console fallback — never throws).
SES_FROM_EMAIL=
# Optional friendly From name shown to recipients (e.g. the service/brand name).
SES_FROM_NAME=
# Region for the SES client (defaults to AWS_REGION above when unset).

# --- KakaoTalk 알림톡 (notifications) --------------------------------------
# Leave blank to log notifications to the console instead of sending.
KAKAO_ALIMTALK_API_KEY=

# --- AI 필드 분석 (Anthropic Claude) ---------------------------------------
# 문서에서 '서명', '날짜', '텍스트 입력' 필드의 위치를 추정하는 데 사용합니다
# (AiFieldAnalyzerService). 비워 두면 외부 호출 없이 결정적 휴리스틱 스텁으로
# 자동 대체됩니다 — 절대 실패하지 않습니다.
ANTHROPIC_API_KEY=
