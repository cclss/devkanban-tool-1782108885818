{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.e2e.json" }]
  },
  "moduleNameMapper": {
    "^@repo/db$": "<rootDir>/../../../packages/db/src/index.ts"
  },
  "testTimeout": 60000
}
